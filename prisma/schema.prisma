generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  answers   Answer[]
}

model Question {
  id         String   @id @default(uuid())
  category   String
  difficulty String
  content    String
  createdAt  DateTime @default(now())
  answers    Answer[]
}

model Answer {
  id         String   @id @default(uuid())
  answerText String
  scoreTotal Int?
  createdAt  DateTime @default(now())
  userId     String
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}
